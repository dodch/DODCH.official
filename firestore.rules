rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is Admin
    function isAdmin() {
      return request.auth != null && request.auth.uid == '4JAqYb2fnEhpqaBv7xWwsFDUXun2';
    }

    // NOTE: Cloud Firestore App Check is set to "Monitoring".
    function isVerifiedApp() {
      return true; 
    }

    function isValidString(text, min, max) {
      return text is string && text.size() >= min && text.size() <= max;
    }

    // Products & Overrides: Public read, Admin write.
    match /products/{productId} {
      allow read: if true;
      // Admin can manage products, including the new size-specific batch, expiry data, and performance metrics.
      allow write: if isAdmin();
    }

    match /product_overrides/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders:
    match /orders/{orderId} {
      // 1. Creation: Admin can create Local Orders; Verified App can create Pending online orders.
      allow create: if (isAdmin() && request.resource.data.get('type', '') == 'local')
        || (isVerifiedApp() && request.resource.data.status == 'Pending');
        
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      
      // 2. Updates:
      allow update: if (
          isAdmin() 
          && (
            // Rule: If already exported, Admin CANNOT change the status (locks archived records).
            // They can still update other meta fields (like correcting batch/date snapshots) or the 'exported' flag itself.
            (resource.data.get('exported', false) == false || !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status']))
          )
        )
        || (
          request.auth != null 
          && resource.data.get('exported', false) == false // Prevent users from touching archived orders
          && (
            // Case A: User claiming a guest order
            (resource.data.userId == 'guest' 
             && request.resource.data.userId == request.auth.uid 
             && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId', 'hasUnseenUpdate']))
            ||
            // Case B: User canceling their own pending order
            (resource.data.userId == request.auth.uid 
             && resource.data.status == 'Pending'
             && request.resource.data.status == 'Cancelled'
             && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']))
          )
        );
        
      allow delete: if isAdmin();
    }

    // Carts: Users only
    match /carts/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    } 

    // Product Reviews: Requires Delivered status
    match /product_reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null
        && isVerifiedApp()
        && request.resource.data.userId == request.auth.uid
        && isValidString(request.resource.data.text, 1, 3000)
        && (request.resource.data.images is list ? request.resource.data.images.size() <= 2 : true)
        && exists(/databases/$(database)/documents/orders/$(request.resource.data.orderId))
        && get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.status == 'Delivered'
        && get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.userId == request.auth.uid;
      
      allow update: if isAdmin() 
        || (request.auth != null 
          && resource.data.userId == request.auth.uid 
          && request.resource.data.userId == request.auth.uid 
          && isValidString(request.resource.data.text, 1, 3000));
      allow delete: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
    }
    
    match /newsletter/{document=**} {
      allow create: if isVerifiedApp() && isValidString(request.resource.data.email, 5, 100);
      allow read, update, delete: if isAdmin();
    }
    
    match /notifications/{notifId} {
      allow create: if isAdmin();
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow update: if request.auth != null 
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isSeen']);
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /subscribers/{token} {
      allow read: if isAdmin();
      allow write: if isVerifiedApp();
    }

    match /messages/{messageId} {
      allow create: if isVerifiedApp()
        && isValidString(request.resource.data.name, 2, 100)
        && isValidString(request.resource.data.email, 5, 100)
        && isValidString(request.resource.data.message, 1, 3000)
        && request.resource.data.status == 'unread'
        && request.resource.data.createdAt is timestamp;
      
      allow update: if isAdmin();
      allow read, delete: if isAdmin();
    }
  }
}