rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is Admin
    function isAdmin() {
      return request.auth != null && request.auth.uid == '4JAqYb2fnEhpqaBv7xWwsFDUXun2';
    }

    // Helper: Require AppCheck for sensitive public-facing writes (spam/abuse protection)
    // NOTE: Firebase Console → App Check → Cloud Firestore must be set to "Monitoring"
    // (not "Enforced") so that product reads work without a token.
    // request.app.verified is true only when a valid AppCheck token is present.
    function isVerifiedApp() {
      return request.app != null && request.app.verified == true;
    }

    // Helper: Validate String Length (prevents buffer overflows/spam)
    function isValidString(text, min, max) {
      return text is string && text.size() >= min && text.size() <= max;
    }

    // Helper: Validate Positive Number
    function isPositiveNumber(num) {
      return num is number && num >= 0;
    }

    // Products & Overrides: Fully public read — no AppCheck needed for browsing.
    // Admin write is protected by auth.
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /product_overrides/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders: 
    // - Create: Allowed from frontend for Spark plan (no billing account needed). Protected by AppCheck.
    // - Read: Admin can read all. Users can read only their own.
    // - Update: Finalized security logic
    match /orders/{orderId} {
      allow create: if isVerifiedApp()
        && request.resource.data.status == 'Pending';
        
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      
      allow update: if isAdmin()
        || (
          request.auth != null 
          && (
            // Case 1: Claiming a guest order
            (resource.data.userId == 'guest' 
             && request.resource.data.userId == request.auth.uid 
             && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId', 'hasUnseenUpdate']))
            ||
            // Case 2: Canceling their own pending order
            (resource.data.userId == request.auth.uid 
             && resource.data.status == 'Pending'
             && request.resource.data.status == 'Cancelled'
             && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']))
          )
        );
      allow delete: if isAdmin();
    }

    // Carts: Users can only read/write their own cart
    match /carts/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    } 

    // Product Reviews: Public read. Writes require auth + AppCheck (prevents fake reviews from bots)
    match /product_reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null
        && isVerifiedApp()
        && request.resource.data.userId == request.auth.uid
        && isValidString(request.resource.data.text, 1, 3000)
        && (request.resource.data.images is list ? request.resource.data.images.size() <= 2 : true)
        && exists(/databases/$(database)/documents/orders/$(request.resource.data.orderId))
        && get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.status == 'Delivered'
        && get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.userId == request.auth.uid;
      
      allow update: if isAdmin() 
        || (request.auth != null 
          && resource.data.userId == request.auth.uid 
          && request.resource.data.userId == request.auth.uid 
          && isValidString(request.resource.data.text, 1, 3000));
      allow delete: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
    }
    
    // Newsletter: Requires AppCheck to prevent spam bots from filling the list
    match /newsletter/{document=**} {
      allow create: if isVerifiedApp()
        && isValidString(request.resource.data.email, 5, 100);
      allow read, update, delete: if isAdmin();
    }
    
    // Notifications: 
    match /notifications/{notifId} {
      allow create: if isAdmin();
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow update: if request.auth != null 
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isSeen']);
    }

    // User Profiles: Users can read/write their own info
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Push Notification Subscribers: Requires AppCheck to prevent fake subscriptions
    match /subscribers/{token} {
      allow read: if isAdmin();
      allow write: if isVerifiedApp();
    }

    // Messages (Contact Form): Requires AppCheck to prevent spam
    match /messages/{messageId} {
      allow create: if isVerifiedApp()
        && isValidString(request.resource.data.name, 2, 100)
        && isValidString(request.resource.data.email, 5, 100)
        && isValidString(request.resource.data.message, 1, 3000)
        && request.resource.data.status == 'unread'
        && request.resource.data.createdAt is timestamp;
      
      allow update: if isAdmin();
      allow read, delete: if isAdmin();
    }
  }
}
