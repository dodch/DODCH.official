rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is Admin
    function isAdmin() {
      return request.auth != null && request.auth.uid == '4JAqYb2fnEhpqaBv7xWwsFDUXun2';
    }

    // NOTE: Cloud Firestore App Check is set to "Monitoring".
    function isVerifiedApp() {
      return true; 
    }

    function isValidString(text, min, max) {
      return text is string && text.size() >= min && text.size() <= max;
    }

    // Products & Overrides: Public read, Admin write.
    // Product documents contain: name, subtitle, description, inci, price, sizes (with batchNumber, expiryDate),
    // batchHistory (array of {size, batchNumber, expiryDate, timestamp, inci}), images, outOfStock, etc.
    match /products/{productId} {
      allow read: if true;
      // Only the admin can write products, including updating batch history records.
      allow write: if isAdmin()
        && (
          !('batchHistory' in request.resource.data)
          || request.resource.data.batchHistory is list
        );
    }

    match /product_overrides/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders:
    match /orders/{orderId} {
      // 1. Creation: Admin can create Local Orders; Verified App can create Pending online orders.
      allow create: if (isAdmin() && request.resource.data.get('type', '') == 'local')
        || (isVerifiedApp() && request.resource.data.status == 'Pending');
        
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      
      // 2. Updates:
      allow update: if (
          isAdmin() 
          && (
            // Rule: If already exported, Admin CANNOT change the status (locks archived records).
            // They can still update other meta fields (like correcting batch/date snapshots) or the 'exported' flag itself.
            (resource.data.get('exported', false) == false || !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status']))
          )
        )
        || (
          request.auth != null 
          && resource.data.get('exported', false) == false // Prevent users from touching archived orders
          && (
            // Case A: User claiming a guest order
            (resource.data.userId == 'guest' 
             && request.resource.data.userId == request.auth.uid 
             && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId', 'hasUnseenUpdate']))
            ||
            // Case B: User canceling their own pending order
            (resource.data.userId == request.auth.uid 
             && resource.data.status == 'Pending'
             && request.resource.data.status == 'Cancelled'
             && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']))
            ||
            // Case C: User reporting a problem with an item in a delivered order
            (resource.data.userId == request.auth.uid 
             && resource.data.status == 'Delivered'
             && resource.data.get('hasReports', false) == false
             && request.resource.data.diff(resource.data).affectedKeys().hasAny(['items'])
             && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['items', 'hasReports', 'hasUnseenReport']))
          )
        );
        
      allow delete: if isAdmin();
    }

    // Carts: Users only
    match /carts/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    } 

    // Product Reviews: Requires Delivered status
    match /product_reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null
        && isVerifiedApp()
        && request.resource.data.userId == request.auth.uid
        && isValidString(request.resource.data.text, 1, 3000)
        && (!('images' in request.resource.data) || request.resource.data.images.size() == 0)
        && exists(/databases/$(database)/documents/orders/$(request.resource.data.orderId))
        && get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.status == 'Delivered'
        && get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.userId == request.auth.uid;
      
      allow update: if isAdmin() 
        || (request.auth != null 
          && resource.data.userId == request.auth.uid 
          && request.resource.data.userId == request.auth.uid 
          && isValidString(request.resource.data.text, 1, 3000)
          && (!('images' in request.resource.data) || request.resource.data.images.size() == 0)
          && (
            // Normal update (not refunded)
            resource.data.get('refunded', false) == false
            ||
            // Post-refund one-time edit (refunded but not yet reviewed after refund)
            (resource.data.get('refunded', false) == true
             && resource.data.get('reviewedAfterRefund', false) == false
             && request.resource.data.get('reviewedAfterRefund', false) == true)
          )
        );
      allow delete: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      
      match /private_data/{docId} {
        allow create: if request.auth != null && isVerifiedApp() && get(/databases/$(database)/documents/product_reviews/$(reviewId)).data.userId == request.auth.uid;
        allow read: if isAdmin();
        allow update, delete: if isAdmin() || (request.auth != null && get(/databases/$(database)/documents/product_reviews/$(reviewId)).data.userId == request.auth.uid);
      }
    }
    
    match /newsletter/{document=**} {
      allow create: if isVerifiedApp() && isValidString(request.resource.data.email, 5, 100);
      allow read, update, delete: if isAdmin();
    }
    
    match /notifications/{notifId} {
      allow create: if isAdmin();
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow update: if request.auth != null 
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isSeen']);
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /subscribers/{token} {
      allow read: if isAdmin();
      allow write: if isVerifiedApp();
    }

    match /back_in_stock_subscriptions/{subscriptionId} {
      // Admin can read all. Auth'd users can read their own.
      // Guest subs (userId == null) are readable so the client can verify subscription status.
      allow read: if isAdmin()
        || (request.auth != null && resource.data.userId == request.auth.uid)
        || resource.data.userId == null;
      allow create: if isVerifiedApp() && (
        request.resource.data.userId == null
        || (request.auth != null && request.resource.data.userId == request.auth.uid)
      );
      // Admin or the owning user can update/delete (e.g. to cancel notification).
      allow update, delete: if isAdmin()
        || (request.auth != null && resource.data.userId == request.auth.uid);
    }

    match /messages/{messageId} {
      allow create: if isVerifiedApp()
        && isValidString(request.resource.data.name, 2, 100)
        && isValidString(request.resource.data.email, 5, 100)
        && isValidString(request.resource.data.message, 1, 3000)
        && request.resource.data.status == 'unread'
        && request.resource.data.createdAt is timestamp;
      
      allow update: if isAdmin();
      allow read, delete: if isAdmin();
    }
  }
}